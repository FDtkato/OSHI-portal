---
import Layout from "../layouts/Layout.astro";
import ArtistTabs from "../components/ArtistTabs.astro";
import NewsSection from "../components/NewsSection.astro";
import LiveSection from "../components/LiveSection.astro";
import XTimeline from "../components/XTimeline.astro";
import InstagramFeed from "../components/InstagramFeed.astro";
import { artists } from "../data/artists";
import type { NewsItem, LiveItem, XPost } from "../data/artists";

// 各アーティストのデータを直接インポート
import tigerleeNewsData from "../data/generated/tigerlee-news.json";
import tigerleeLiveData from "../data/generated/tigerlee-live.json";
import gagagaspNewsData from "../data/generated/gagagasp-news.json";
import gagagaspLiveData from "../data/generated/gagagasp-live.json";
import tigerleeXPostsData from "../data/generated/tigerlee-x-posts.json";
import gagagaspXPostsData from "../data/generated/gagagasp-x-posts.json";

const artistData: Record<string, { news: NewsItem[]; live: LiveItem[]; xPosts: XPost[] }> = {
  tigerlee: {
    news: tigerleeNewsData as NewsItem[],
    live: tigerleeLiveData as LiveItem[],
    xPosts: tigerleeXPostsData as XPost[],
  },
  gagagasp: {
    news: gagagaspNewsData as NewsItem[],
    live: gagagaspLiveData as LiveItem[],
    xPosts: gagagaspXPostsData as XPost[],
  },
};

const lastUpdated = new Date().toLocaleString("ja-JP", {
  timeZone: "Asia/Tokyo",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  hour: "2-digit",
  minute: "2-digit",
});
---

<Layout title="推しポータル">
  <ArtistTabs />

  <main class="max-w-7xl mx-auto px-4 py-6">
    {artists.map((artist, i) => (
      <div
        data-artist-section={artist.id}
        class:list={[i !== 0 && "hidden"]}
      >
        {/* ヘッダーバナー */}
        <div class="mb-6 p-4 rounded-2xl bg-gradient-to-r from-gray-800/80 to-gray-900/80 border border-gray-700/50">
          <div class="flex items-center justify-between">
            <div>
              <h1 class="text-2xl font-bold" style={`color: ${artist.color}`}>
                {artist.name}
              </h1>
              <p class="text-xs text-gray-500 mt-1">
                最終更新: {lastUpdated}
              </p>
            </div>
            <div class="flex gap-2">
              <a
                href={artist.officialUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="px-3 py-1.5 text-xs bg-white/5 hover:bg-white/10 rounded-lg transition-colors text-gray-400 hover:text-white"
              >
                公式サイト
              </a>
            </div>
          </div>
        </div>

        {/* ダッシュボードグリッド */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {/* 左カラム: ライブ情報 + お知らせ */}
          <div class="space-y-6">
            <LiveSection
              items={artistData[artist.id].live}
              liveUrl={artist.liveUrl}
              color={artist.color}
            />
            <NewsSection
              items={artistData[artist.id].news}
              officialUrl={artist.officialUrl}
              color={artist.color}
            />
          </div>

          {/* 右カラム: SNS */}
          <div class="space-y-6">
            <XTimeline handle={artist.xHandle} posts={artistData[artist.id].xPosts} />
            <InstagramFeed handle={artist.instagramHandle} />
          </div>
        </div>
      </div>
    ))}
  </main>

  {/* フッター */}
  <footer class="border-t border-gray-800 mt-12 py-6 text-center text-xs text-gray-600">
    <p>推しポータル — ファンのための非公式情報集約サイト</p>
  </footer>
</Layout>
