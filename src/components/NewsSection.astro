---
import type { NewsItem } from "../data/artists";

interface Props {
  items: NewsItem[];
  officialUrl: string;
  color: string;
}

const { items, officialUrl, color } = Astro.props;
const sortedItems = [...items].sort((a, b) => b.date.localeCompare(a.date));
---

<section>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xl font-bold flex items-center gap-2">
      <span class="text-2xl">📢</span> お知らせ
    </h2>
    <a
      href={officialUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm text-gray-400 hover:text-gray-200 transition-colors"
    >
      公式サイト →
    </a>
  </div>

  {items.length === 0 ? (
    <p class="text-gray-500 text-sm py-8 text-center">
      お知らせはまだ取得されていません。
    </p>
  ) : (
    <div class="space-y-3 max-h-[24rem] overflow-y-auto pr-1">
      {sortedItems.map((item) => (
        <a
          href={item.url}
          target="_blank"
          rel="noopener noreferrer"
          class="block p-4 bg-gray-800/50 rounded-xl border border-gray-700/50 hover:border-gray-600 hover:bg-gray-800 transition-all group"
        >
          <div class="flex items-start gap-3">
            <div
              class="shrink-0 w-1 h-full min-h-[2.5rem] rounded-full"
              style={`background-color: ${color}`}
            />
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 mb-1">
                <time class="text-xs text-gray-500 tabular-nums">{item.date}</time>
                {item.category && (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-white/5 text-gray-400">
                    {item.category}
                  </span>
                )}
              </div>
              <p class="text-sm text-gray-200 group-hover:text-white transition-colors leading-relaxed">
                {item.title}
              </p>
            </div>
            <span class="text-gray-600 group-hover:text-gray-400 transition-colors shrink-0">
              ↗
            </span>
          </div>
        </a>
      ))}
    </div>
  )}
</section>
